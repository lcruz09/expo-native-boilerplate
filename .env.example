# =============================================================================
# Expo Native Boilerplate — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values.
# Never commit .env to version control.
#
# Variables prefixed with EXPO_PUBLIC_ are bundled into the client app.
# Variables without the prefix are build-time only (e.g., CI, Sentry upload).
# =============================================================================

# -----------------------------------------------------------------------------
# Supabase (required)
# -----------------------------------------------------------------------------
# Your Supabase project URL — found in Project Settings > API
EXPO_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# Publishable (anon) key — found in Project Settings > API
EXPO_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-supabase-publishable-key

# Deep-link URL used as the redirect target after email confirmation.
# Must match a URL registered in your Supabase Auth settings.
# Format: <scheme>://auth-callback  (scheme is defined in app.config.js)
EXPO_PUBLIC_AUTH_CALLBACK_URL=expo-native-boilerplate://auth-callback

# -----------------------------------------------------------------------------
# API Provider (optional)
# -----------------------------------------------------------------------------
# Which backend provider to use. Currently only "supabase" is supported.
EXPO_PUBLIC_API_PROVIDER=supabase

# -----------------------------------------------------------------------------
# Sentry — Error Monitoring (optional)
# -----------------------------------------------------------------------------
# Client-side DSN — shown in Sentry project Settings > Client Keys
EXPO_PUBLIC_SENTRY_DSN=

# Build-time Sentry config — used by the Sentry Expo plugin during `eas build`
# to upload source maps. Not bundled into the app.
SENTRY_DSN=
SENTRY_ORG=your-sentry-org
SENTRY_PROJECT=your-sentry-project
